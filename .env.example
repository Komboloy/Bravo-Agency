# =====================================================================
# BRAVO! Agency — Environment variables
# Copier en .env.local pour le dev. Sur Vercel/Infomaniak : config UI.
# =====================================================================

# --- Database (Postgres) ---
# Pour le local : Postgres local OU connection string Neon.
# Récupérer la string sur https://console.neon.tech (free tier)
# Format : postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/bravo?sslmode=require

# --- Payload ---
# Secret long et aléatoire (ex: `openssl rand -base64 32`)
# Sert à signer les JWT de l'admin Payload.
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- URLs ---
# URL publique du site. No trailing slash.
# Local : http://localhost:3000
# Prod : https://www.bravo-agency.be
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Cron / Preview ---
# Secret pour authentifier les cron jobs (Vercel Cron, etc.)
CRON_SECRET=CHANGE_ME

# Secret pour valider les requêtes de preview (Live Preview)
PREVIEW_SECRET=CHANGE_ME
